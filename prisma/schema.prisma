generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Role disederhanakan sesuai permintaan
enum Role {
  ADMIN // Wali Dosen
  USER  // Mahasiswa
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(USER)
  name      String
  
  // Relasi ke Student jika user adalah Mahasiswa
  student   Student? 
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Student {
  id               String   @id @default(uuid())
  nim              String   @unique
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // 5 Variabel Input Utama (Sesuai kesepakatan baru)
  gender           String   // 'Laki-laki' / 'Perempuan'
  age              Int
  attendanceRate   Float    // Kehadiran (%)
  assignmentScore  Float    // Nilai Tugas Rata-rata
  discussionPart   Float    // Partisipasi Diskusi Rata-rata
  
  // Data untuk evaluasi setelah semester berakhir
  gpa              Float?   // IPS (Hanya diisi di akhir semester)
  
  predictions      Prediction[]
  progressHistory  AcademicProgress[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Prediction {
  id                  String   @id @default(uuid())
  studentId           String
  student             Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  riskLevel           String   // Risiko Rendah, Sedang, Tinggi
  probability         Float    
  academicHealthScore Float    
  dominantFactors     Json?    // Feature Importance
  
  recommendations     Recommendation[]

  createdAt           DateTime @default(now())
}

model Recommendation {
  id            String     @id @default(uuid())
  predictionId  String
  prediction    Prediction @relation(fields: [predictionId], references: [id], onDelete: Cascade)
  message       String     

  createdAt     DateTime   @default(now())
}

model AcademicProgress {
  id              String   @id @default(uuid())
  studentId       String
  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  semester        Int
  attendanceRate  Float
  assignmentScore Float
  discussionPart  Float
  gpa             Float    // IPS aktual
  
  recordedAt      DateTime @default(now())
}