generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Role disederhanakan sesuai permintaan
enum Role {
  ADMIN // Wali Dosen
  USER  // Mahasiswa
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  role      Role     @default(USER)
  name      String
  
  // Relasi ke Student jika user adalah Mahasiswa
  student   Student? 
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Student {
  id               String   @id @default(uuid())
  
  // Data Profil Utama
  name             String   
  nim              String   @unique
  
  // 3 Variabel Metrik Utama (Dengan default value)
  attendanceRate   Float    @default(100) 
  assignmentScore  Float    @default(100) 
  discussionPart   Float    @default(10)  

  // Data untuk evaluasi setelah semester berakhir
  gpa              Float?   // IPS (Hanya diisi di akhir semester)

  // ==========================================
  // PERBAIKAN RELASI PRISMA (AGAR TIDAK ERROR)
  // ==========================================
  
  // 1. Relasi Balik ke User (Dibuat opsional '?' agar form tidak wajib ngirim userId)
  userId           String?  @unique
  user             User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 2. Relasi Balik ke Prediction & AcademicProgress (Cukup sediakan array kosong)
  predictions      Prediction[]
  progressHistory  AcademicProgress[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Prediction {
  id                  String   @id @default(uuid())
  studentId           String
  student             Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  riskLevel           String   // Risiko Rendah, Sedang, Tinggi
  probability         Float    
  academicHealthScore Float    
  dominantFactors     Json?    // Feature Importance
  
  recommendations     Recommendation[]

  createdAt           DateTime @default(now())
}

model Recommendation {
  id            String     @id @default(uuid())
  predictionId  String
  prediction    Prediction @relation(fields: [predictionId], references: [id], onDelete: Cascade)
  message       String     

  createdAt     DateTime   @default(now())
}

model AcademicProgress {
  id              String   @id @default(uuid())
  studentId       String
  student         Student  @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  semester        Int
  attendanceRate  Float
  assignmentScore Float
  discussionPart  Float
  gpa             Float    // IPS aktual
  
  recordedAt      DateTime @default(now())
}